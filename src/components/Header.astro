---
import "../styles/custom.css";
import Logo from "../components/Logo.astro";
import Navigation from "../components/Navigation.astro";
const { variant = "dark" } = Astro.props;
---

<header>
  <div class="logo-header">
    <div>
      <a href="#">
        <Logo />
      </a>
    </div>
    <a href="#">
      <p>
        KULTURHUSET
        <span>BRØNDEN</span>
      </p>
    </a>
  </div>
  <Navigation />
</header>

<style>
  p {
    font-family: var(--font-family-beatrice);
    font-size: 24px;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 2rem;
  }

  .logo-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .logo-header div {
    min-width: 50px;
  }

  .logo-header span {
    display: block;
  }
</style>
