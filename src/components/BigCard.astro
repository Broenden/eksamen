---
import { Image } from "astro:assets";
import CtaDefault from "./CtaDefault.astro";
// const { placeholder, buttonText, text, title } = Astro.props;
const { img, imgTekst, tekst, tekst2, titel, ctaTekst, href, order, variant = "no-button", target } = Astro.props;
---

<section class={`big-card big-card--${variant} `}>
  <Image src={img} alt={imgTekst} />
  <div class="content">
    <h2>{titel}</h2>
    <p>{tekst}</p>
    <p>{tekst2}</p>
    <div class="cta">
      <CtaDefault href={href} tekst={ctaTekst} target={target} />
    </div>
  </div>
</section>

<style define:vars={{ order }}>
  .content {
    order: var(--order);
    display: flex;
    justify-content: center;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    margin: 1rem 4rem;
  }

  .big-card {
    margin: 9rem 0;
  }

  .cta {
    display: none;
  }
  .big-card--button .cta {
    display: block;
  }

  .big-card--button-pink .cta {
    display: block;
  }

  .big-card--button-pink {
    background-color: var(--card-color-pink);
    padding: 2rem 0;
    margin-bottom: 0;
  }

  @media (width>=800px) {
    .big-card {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }
  }
</style>
