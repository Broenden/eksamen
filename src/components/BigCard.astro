---
import { Image } from "astro:assets";
import fb from "../assets/fb.svg";
import CtaDefault from "./CtaDefault.astro";
// const { placeholder, buttonText, text, title } = Astro.props;
const { img, imgTekst, tekst, titel, ctaTekst, href, variant = "no-button" } = Astro.props;
---

<section class={`big-card big-card--${variant} `}>
  <Image src={img} alt={imgTekst} />
  <div class="content">
    <h2>{titel}</h2>
    <p>{tekst}</p>
    <div class="cta">
      <CtaDefault href={href} tekst={ctaTekst} />
    </div>
  </div>
</section>

<style>
  .content {
    display: flex;
    justify-content: center;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .big-card--no-button {
    margin: 4rem 1rem;
  }

  .cta {
    display: none;
  }
  .big-card--button {
    display: block;
  }

  @media (width>=800px) {
    .big-card {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 5rem;
    }
  }
</style>
