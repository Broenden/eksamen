---
import "../styles/custom.css";
import "../styles/general.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const { heading, heroImg, heroImgTekst, video, navColor, ctaVariant, logoVariant, headerVariant, burgerVariant, footerLogo, videoWebm } = Astro.props;

//@ts-nocheck
---

<html lang="da">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="generator" content="" />
    <meta name="description" content="Kulturhuset Brønden" />
    <title>{heading}</title>
  </head>
</html>
<body>
  <Header img={heroImg} imgTekst={heroImgTekst} video={video} videoWebm={videoWebm} navColor={navColor} ctaVariant={ctaVariant} logoVariant={logoVariant} variant={headerVariant} burgerVariant={burgerVariant} />
  <main>
    <slot />
  </main>
  <Footer footerLogo={footerLogo} />
</body>

<style></style>
