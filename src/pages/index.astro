---
//@ts-nocheck
import "../styles/custom.css";
import { Image } from "astro:assets";
import IndexCardContainer from "../components/IndexCardContainer.astro";
import PageLayout from "../Layouts/PageLayout.astro";
import BigCard from "../components/BigCard.astro";
import SmallCard from "../components/SmallCard.astro";
import broendenHero from "../assets/broendenHero.png";
import videobroenden from "../../public/videobroenden.mp4";
import Logo from "../components/Logo.astro";

const response = await fetch(`https://bjirvinbqadjnyjgfaze.supabase.co/rest/v1/kalender?limit=3`, {
  headers: {
    apikey: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJqaXJ2aW5icWFkam55amdmYXplIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMDExMTIsImV4cCI6MjA5NDU3NzExMn0.7zVbvnasSjz7OidFqNKZ2ahvwutN0cPIuVfSlZBV6ks",
  },
});
const data = await response.json();
---

<PageLayout heading="Index" heroVideo={videobroenden} heroImgTekst="Kulturhuset Brønden" navColor="light" ctaVariant="light" headerVariant="light">
  <div class="page-content">
    <section class="section-1">
      <h1>Det sker i Kulturhuset Brønden</h1>

      <IndexCardContainer kalender={data} />

      <a class="til-kalender" href="/kalender">Se alle arrangementer &rarr; </a>
    </section>

    <section class="section-2">
      <BigCard
        img={import("../assets/forside/forsideRav.svg")}
        imgTekst="billed af optrædne i kulturhuset brønden. "
        titel="Rav"
        tekst="RAV arrangerer koncerter og er til for musikken, byen og kulturen. Fokus er på ny musik og trends, samt musikgenrerne rap/hiphop, pop og roots 'n' hybrid. Der afholdes primært koncerter og aktiviteter i Kulturhuset Brønden. Der kan være 500 publikummer til koncerterne. Blandt andre har RAV lavet koncerter med Lamin, RH, Dejah Makar, AFSKUM og UNG-SKAB."
        ctaTekst="Læs mere"
        href="/rav"
        variant="button"
      />

      <article class="big-card_boennen">
        <BigCard
          img={import("../assets/forside/forsideBoennnen2.svg")}
          imgTekst="cafe på kulturhuset brønden. "
          titel="Bønnen"
          tekst="Caféen Brønden & Bønnen danner ramme om gode smagsoplevelser, fællesskab og hverdagsmøder mellem Brøndbys borgere."
          ctaTekst="Læs mere"
          href="/boennen"
          order="-1"
          variant="button"
        />

        <div class="OverlayCard">
          <SmallCard tekst="Brønden & Bønnen holder åbent på hverdage fra kl. 10 til 14." variant="pink-nobutton" />
        </div>
      </article>

      <div class="yellow">
        <BigCard
          class="big-card-bibliotek"
          img={import("../assets/forside/fpo.png")}
          imgTekst="biblioteket på kulturhuset brønden. "
          titel="Biblioteket"
          tekst="På biblioteket Brønden kan du låne, aflevere og hente reserverede materialer i alle husets åbne timer – også når det ikke er bibliotekspersonale tilstede."
          ctaTekst="Læs mere"
          href="/biblioteket"
          order="1"
          variant="button"
        />
      </div>
      <div class="logo-container">
        <Logo variant="lightblue" />
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .page-content {
    display: grid;
    grid-template-rows: auto 1fr auto;
    max-width: 1200px;
    margin: 0 auto;
    row-gap: 1rem;
  }

  h1 {
    margin-top: 5rem;
    margin-bottom: 2rem;
    font-size: 2.5rem;
    text-align: center;
  }

  .til-kalender {
    text-align: end;
    display: block;
    margin-right: 3rem;
  }

  .til-kalender:hover {
    text-decoration: underline;
  }

  .big-card_boennen {
    position: relative;
    z-index: 1;
    margin: 2rem 0;
  }
  .big-card-bibliotek {
    margin: 2rem 0;
  }
  .section-2 {
    margin: 2rem 0;
  }

  .big-card_boennen :global(.big-card .content) {
    margin: 1rem 2rem;
  }
  .section-2 :global(.big-card .content) {
    margin: 1rem 2rem;
  }
  .OverlayCard {
    position: absolute;
    width: 150px;
    height: 200px;
    top: 45%;
    right: 15%;
    z-index: 10;
  }

  .yellow {
    background-color: var(--card-color-yellow);
    padding: 2rem;
  }
  .logo-container {
    max-width: 200px;
    min-width: 200px;
    position: relative;
    transform: rotate(120deg);
    bottom: 100px;
    left: -20px;
    place-self: left;
    grid-area: 1/1;
    z-index: -1;
  }
  @media (min-width: 800px) {
    .til-kalender {
      margin-bottom: 5rem;
    }
    .OverlayCard {
      position: absolute;
      width: 250px;
      height: 150px;
      top: 60%;
      right: 5%;
      z-index: 10;
    }
  }
</style>
