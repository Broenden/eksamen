---
//@ts-nocheck
import { Image } from "astro:assets";
import IndexCardContainer from "../components/IndexCardContainer.astro";
import PageLayout from "../Layouts/PageLayout.astro";
import BigCard from "../components/BigCard.astro";
import SmallCard from "../components/SmallCard.astro";
import broendenHero from "../assets/broendenHero.png";
import videobroenden from "../videobroenden.mp4";

const response = await fetch(`https://bjirvinbqadjnyjgfaze.supabase.co/rest/v1/kalender?limit=3`, {
  headers: {
    apikey: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJqaXJ2aW5icWFkam55amdmYXplIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMDExMTIsImV4cCI6MjA5NDU3NzExMn0.7zVbvnasSjz7OidFqNKZ2ahvwutN0cPIuVfSlZBV6ks",
  },
});
const data = await response.json();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
  </head>
  <body>
    <PageLayout heading="Index" heroVideo={videobroenden} heroImgTekst="Kulturhuset Brønden" navColor="light" ctaVariant="light" headerVariant="light">
      <section>
        <h1>Det sker i Kulturhuset Brønden</h1>

        <IndexCardContainer kalender={data} />

        <a class="til-kalender" href="/kalender">Se alle arrangementer &rarr; </a>
      </section>

      <section>
        <BigCard
          img={import("../assets/forside/forsideRav.svg")}
          imgTekst="billed af optrædne i kulturhuset brønden. "
          titel="Rav"
          tekst="RAV arrangerer koncerter og er til for musikken, byen og kulturen. Fokus er på ny musik og trends, samt musikgenrerne rap/hiphop, pop og roots 'n' hybrid. Der afholdes primært koncerter og aktiviteter i Kulturhuset Brønden. Der kan være 500 publikummer til koncerterne.
Blandt andre har RAV lavet koncerter med Lamin, RH, Dejah Makar, AFSKUM og UNG-SKAB."
          ctaTekst="Læs mere"
          href="/rav"
          variant="button"
        />

        <article class="big-card_boennen">
          <BigCard
            img={import("../assets/forside/forsideBoennen.svg")}
            imgTekst="cafe på kulturhuset brønden. "
            titel="Bønnen"
            tekst="Caféen Brønden & Bønnen danner ramme om gode smagsoplevelser, fællesskab og hverdagsmøder mellem Brøndbys borgere."
            ctaTekst="Læs mere"
            href="/boennen"
            order="-1"
            variant="button"
          />

          <div class="OverlayCard">
            <SmallCard tekst="Brønden & Bønnen holder åbent på hverdage fra kl. 10 til 14." variant="pink-nobutton" />
          </div>
        </article>

        <BigCard
          class="big-card-bibliotek"
          img={import("../assets/forside/fpo.png")}
          imgTekst="biblioteket på kulturhuset brønden. "
          titel="Biblioteket"
          tekst="På biblioteket Brønden kan du låne, aflevere og hente reserverede materialer i alle husets åbne timer – også når det ikke er bibliotekspersonale tilstede."
          ctaTekst="Læs mere"
          href="/biblioteket"
          order="1"
          variant="button"
        />
      </section>
    </PageLayout>
  </body>
</html>

<style>
  section :global(.big-card img) {
    margin-left: 2rem;
    max-width: 700px;
  }

  h1 {
    margin-top: 5rem;
    margin-bottom: 2rem;
    font-size: 2.5rem;
    text-align: center;
  }

  .til-kalender {
    text-align: end;
    display: block;
    margin-right: 3rem;
    margin-bottom: 5rem;
  }

  .til-kalender:hover {
    text-decoration: underline;
  }

  .big-card_boennen {
    position: relative;
    z-index: 1;
  }

  .OverlayCard {
    position: absolute;
    width: 250px;
    height: 150px;
    top: 61%;
    right: 12%;

    z-index: 10;
  }

  @media (width<800px) {
    .menu {
      gap: 12rem;
    }
  }
</style>
