<style>
  .page-content {
    display: grid;
    grid-template-rows: auto 1fr auto;
    max-width: 1200px;
    margin: 0 auto;
    row-gap: 1rem;
    margin-bottom: 2rem;
  }
  section {
    margin: 0 2rem;
  }

  a {
    font: inherit;
    text-decoration: underline;
  }

  p {
    margin: 1rem 0;
  }

  .om :global(section),
  .historie :global(section) {
    margin-bottom: 1rem;
    margin-top: 0;
    gap: 2rem;
  }

  section :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .historie :global(.content) {
    justify-content: start;
  }

  li {
    font-family: var(--font-family-montserrat);
    font-size: var(--p-small-size);
    color: var(--text-color-dark);
    font-weight: var(--font-weight-light);
    margin-bottom: 0.5ch;
    list-style-type: none;
  }
  h4 {
    margin-bottom: 1ch;
  }

  .personale p {
    margin: 0;
  }

  .bold {
    font-weight: var(--font-weight-medium);
  }

  .personale {
    margin-top: 2rem;
  }

  .personale .stilling {
    margin: 1ch 0 3ch 0;
  }

  .personale-card {
    background-color: var(--card-color-yellow);
    border-radius: var(--border-radius);
    padding: 1.6rem 1rem 0.1rem 1rem;
    margin-top: 0.8rem;
  }

  .personale article section {
    margin: 0;
    margin-top: 1.5rem;
  }

  .info-link {
    margin-top: 2rem;
    margin-left: 0.2rem;
  }

  @media (width>=800px) {
    .personale article:last-child {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: repeat(3, 1fr);
      margin-top: 1rem;
      gap: 4rem;
      row-gap: 0.5rem;
    }

    .personale article section:first-of-type {
      grid-column: 1/2;
      grid-row: 1/2;
    }

    .personale article section:nth-of-type(2) {
      grid-column: 1/2;
      grid-row: 2/-1;
    }

    .personale article section:nth-of-type(3) {
      grid-column: -1/-2;
      grid-row: 1/3;
    }
    /* .historie :global(.small-card) {
      top: -110px;
      right: -550px;
      max-width: 30vw;
    } */
  }
</style>
